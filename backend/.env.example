JWT_SECRET=989ff864a17a23559e35bf68c8708da6d09c3c227042f9dacd3293cf82501b21
ENCRYPTION_SECRET=another-long-random-string-for-aes-256
DB_PATH=hive.db
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# ── Launch free window ────────────────────────────────────────────────────────
# During this window ALL users get full access (BYOK + Ollama) for free.
# Set FREE_UNTIL to 3 months after your go-live date.
LAUNCH_DATE=2026-03-20
FREE_UNTIL=2026-09-20

# NOTE: There is NO server-side GROQ_API_KEY.
# Every user supplies their own API keys via Profile → API Keys.
# Free users add their Groq key (free at console.groq.com).
# BYOK users add OpenAI / Anthropic / Google keys.
# Ollama users set their local Ollama URL.

# ── CORS (comma-separated, no spaces) ─────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
# Production:
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Frontend URL (used in Stripe payment redirect URLs) ───────────────────────
FRONTEND_URL=http://localhost:3000

# ── Firebase Admin SDK (for Google Sign-In — optional) ────────────────────────
# Download JSON from: Firebase Console → Project Settings → Service Accounts → Generate new private key

# OR use individual env vars (e.g. on Railway / Cloud Run):
# FIREBASE_PROJECT_ID=your-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# ── Razorpay (India payments — razorpay.com) ──────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# ── Stripe (Global payments — stripe.com) ─────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create these price IDs in your Stripe dashboard (recurring monthly):
STRIPE_PRICE_BYOK=price_...     # $2/month
STRIPE_PRICE_OLLAMA=price_...   # $3/month

# Stripe webhook must handle these events (configure in Stripe dashboard):
#   checkout.session.completed
#   invoice.payment_succeeded
#   customer.subscription.deleted
