# SECURITY WARNING: Change all secrets before deploying!
# Generate secure random values with: openssl rand -hex 32

# ── Core Security ─────────────────────────────────────────
# CHANGE THESE - use strong random strings (64+ hex chars)
JWT_SECRET=change-this-to-random-32-byte-hex-string
ENCRYPTION_SECRET=change-this-to-different-random-32-byte-hex-string

# Database (SQLite path)
DB_PATH=hive.db

# ── Supabase Configuration ────────────────────────────────
# Required for authentication to work
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── CORS Configuration ──────────────────────────────────
# Desktop app origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Frontend URL ────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Launch Settings ─────────────────────────────────────
LAUNCH_DATE=2026-03-20
FREE_UNTIL=2026-06-20

# NOTE: NO server-side API keys for AI models.
# Users supply their own keys via Profile → API Keys.

# ── Optional: Payments ──────────────────────────────────
# Uncomment and set these to enable payments
# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_BYOK=price_...
# STRIPE_PRICE_OLLAMA=price_...
